        "model": {
          "conditions": [
            {
              "evaluator": { "params": [0], "type": "gt" },
              "operator": { "type": "and" },
              "query": { "params": ["C"] },
              "reducer": { "params": [], "type": "last" },
              "type": "query"
            }
          ],
          "datasource": { "type": "__expr__", "uid": "__expr__" },
          "expression": "A",
          "intervalMs": 1000,
          "maxDataPoints": 43200,
          "refId": "C",
          "type": "threshold"
        }
