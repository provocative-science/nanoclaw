      "summary": "Container/BOP supervisor lock is set",
      "description": "app.supervisor.lock is true. Unforced commands are blocked until an operator clears the lock in the GUI (POST /supervisor/clear_lock). Ghost host monitor will narrate recovery/interlocks.",
      "runbook_url": "https://github.com/provocative-science/nanoclaw/blob/main/scripts/alert-monitor/deploy/GRAFANA_ONCALL.md"
    },
    "data": [
      {
        "refId": "A",
        "relativeTimeRange": { "from": 600, "to": 0 },
        "datasourceUid": "grafanacloud-prom",
        "model": {
          "editorMode": "code",
          "expr": "co3ntrol_supervisor_lock{subsystem=\"container\"} == 1",
          "instant": true,
          "intervalMs": 1000,
          "maxDataPoints": 43200,
          "range": false,
          "refId": "A"
        }
      },
      {
