      "team": "plant",
      "severity": "warning",
      "subsystem": "container"
    },
    "annotations": {
      "summary": "Container interlock blocked a command while unlocked",
      "description": "triggered_interlocks fired within the last 2m and supervisor_lock is still 0. Does not page when already locked (avoids double-page with lock alert).",
      "runbook_url": "https://github.com/provocative-science/nanoclaw/blob/main/scripts/alert-monitor/deploy/GRAFANA_ONCALL.md"
    },
    "data": [
      {
        "refId": "A",
        "relativeTimeRange": { "from": 600, "to": 0 },
        "datasourceUid": "grafanacloud-prom",
        "model": {
          "editorMode": "code",
          "expr": "(max_over_time(co3ntrol_interlock_triggered{subsystem=\"container\"}[2m]) == 1) and on(subsystem) (co3ntrol_supervisor_lock{subsystem=\"container\"} == 0)",
          "instant": true,
          "intervalMs": 1000,
          "maxDataPoints": 43200,
          "range": false,
          "refId": "A"
        }
      },
      {
        "refId": "C",
        "relativeTimeRange": { "from": 0, "to": 0 },
