# Copy to secrets/alert-monitor.env (gitignored) or /etc/alert-monitor.env and chmod 600.
# Used by deploy/alert-monitor.service EnvironmentFile=.

# Liquefaction co3ntrol-rs (temporary stand-in for lichost: pirate-host)
LIQ_BASE_URL=http://10.3.0.213:3000

# Container / BOP co3ntrol-rs (bop-host)
BOP_BASE_URL=http://10.3.0.94:3000

# Bearer token(s) — AUTH_TOKEN is the shared default; override per host if needed
AUTH_TOKEN=
# LIQ_AUTH_TOKEN=
# BOP_AUTH_TOKEN=

# NanoClaw IPC delivery — write via main (privileged), deliver to plant channel
# Registered folder telegram_carbon-capture (chat "Carbon Capture")
NANOCLAW_ROOT=/home/co2/provocative/nanoclaw
IPC_GROUP_FOLDER=telegram_main
TARGET_JID=tg:-1004294109828
# Leave empty for chat default (no forum topic)
TARGET_THREAD_ID=

# Timing
POLL_INTERVAL_S=1
COOLDOWN_S=300
# Treat host as "recently deployed/restarted" if app.systick < this many seconds
RECENT_DEPLOY_WINDOW_S=1800

# Ghost plant-alert mute: toggled by tagging Ghost with "mute alerts" /
# "unmute alerts". State file: $NANOCLAW_ROOT/data/alert-monitor/mute.json
# (written by NanoClaw host; alert-monitor reads it before IPC fire).

# Set to 1 to log IPC payloads without writing (or use --dry-run)
# DRY_RUN=0
