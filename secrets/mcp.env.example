# Copy to secrets/mcp.env (gitignored) and replace placeholders.
# Use single quotes around values that might contain special shell characters.
#
#   cp secrets/mcp.env.example secrets/mcp.env
#   $EDITOR secrets/mcp.env
#   ./scripts/render-mcp.sh
#
# Restart nanoclaw after changing secrets.

# Internal integration secret from https://www.notion.so/my-integrations — connect pages to the integration.
NOTION_TOKEN='ntn_REPLACE_WITH_INTEGRATION_SECRET'

GRAFANA_URL='https://provocativerob.grafana.net'
GRAFANA_SERVICE_ACCOUNT_TOKEN='PASTE_GRAFANA_SERVICE_ACCOUNT_TOKEN_ROTATE_IF_LEAKED'
