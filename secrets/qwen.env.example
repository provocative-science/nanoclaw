# OpenAI-compatible light LLM profile for NanoClaw (first provider: Qwen).
#
# Copy to secrets/qwen.env (gitignored) and fill in the API key.
# On a laptop the key often lives in ~/.config/dotfiles-autocommit.env as QWEN_API_KEY —
# copy that value onto bob49 here (do not commit it).
#
#   cp secrets/qwen.env.example secrets/qwen.env
#   chmod 600 secrets/qwen.env
#   $EDITOR secrets/qwen.env
#
# Restart nanoclaw after changing secrets.
# Light path only: no tools / MCP / Claude sessions. Use /qwen or model:qwen in chat,
# or schedule_task with model: "qwen".

QWEN_API_KEY='PASTE_QWEN_API_KEY'
QWEN_BASE_URL='https://inference.provocative.earth/v1'
QWEN_MODEL='qwen3.6-35b'
